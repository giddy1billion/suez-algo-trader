# ============================================================================
# ALPACA ALGO TRADER — ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git!

# --- Account Mode ---
# Set to "paper" for paper trading, "live" for real money
TRADING_MODE=paper

# --- Alpaca Paper Trading ---
ALPACA_PAPER_API_KEY=your_paper_api_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# --- Alpaca Live Trading ---
ALPACA_LIVE_API_KEY=your_live_api_key_here
ALPACA_LIVE_SECRET_KEY=your_live_secret_key_here
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# --- Data Feed ---
# "iex" (free) or "sip" (paid, all exchanges)
ALPACA_DATA_FEED=iex

# --- Risk Management ---
MAX_POSITION_SIZE_PCT=0.02
MAX_DAILY_LOSS_PCT=0.05
MAX_PORTFOLIO_EXPOSURE=0.80
MAX_SINGLE_STOCK_PCT=0.15
MAX_LEVERAGE=1.0
DEFAULT_STOP_LOSS_PCT=0.03
DEFAULT_TAKE_PROFIT_PCT=0.06

# --- Strategy ---
ACTIVE_STRATEGY=momentum
TRADING_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA,META,BTC/USD,ETH/USD
TIMEFRAME=1Hour
LOOKBACK_BARS=200

# --- ML Model ---
ML_MODEL_PATH=models/latest_model.joblib
ML_RETRAIN_INTERVAL_HOURS=24
ML_MIN_CONFIDENCE=0.65

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
NOTIFY_ON_TRADE=true
NOTIFY_ON_ERROR=true

# --- Database ---
DATABASE_URL=sqlite:///data_cache/trading.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/trader.log
