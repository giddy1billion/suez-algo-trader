# ============================================================================
# ALPACA ALGO TRADER — ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git!

# --- Account Mode ---
# Set to "paper" for paper trading, "live" for real money
TRADING_MODE=paper

# --- Alpaca Paper Trading ---
ALPACA_PAPER_API_KEY=your_paper_api_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets/v2

# --- Alpaca Live Trading ---
ALPACA_LIVE_API_KEY=your_live_api_key_here
ALPACA_LIVE_SECRET_KEY=your_live_secret_key_here
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# --- Data Feed ---
# "iex" (free) or "sip" (paid, all exchanges)
ALPACA_DATA_FEED=iex

# --- Trading Loop ---
TRADING_INTERVAL=60
MAX_CONSECUTIVE_ERRORS=5
ERROR_COOLDOWN_SECONDS=300

# --- Risk Management ---
MAX_POSITION_SIZE_PCT=0.02
MAX_DAILY_LOSS_PCT=0.05
MAX_PORTFOLIO_EXPOSURE=0.80
MAX_SINGLE_STOCK_PCT=0.15
MAX_LEVERAGE=1.0
MAX_OPEN_POSITIONS=20
MAX_ORDERS_PER_DAY=100
MAX_CORRELATED_POSITIONS=3
DEFAULT_STOP_LOSS_PCT=0.03
DEFAULT_TAKE_PROFIT_PCT=0.06

# --- Strategy ---
ACTIVE_STRATEGY=momentum
TRADING_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA,META,BTC/USD,ETH/USD
TIMEFRAME=1Hour
LOOKBACK_BARS=200

# --- Strategy Parameters (Momentum) ---
MOMENTUM_FAST_EMA=12
MOMENTUM_SLOW_EMA=26
MOMENTUM_RSI_PERIOD=14
MOMENTUM_RSI_OVERSOLD=30
MOMENTUM_RSI_OVERBOUGHT=70
MOMENTUM_ATR_PERIOD=14
MOMENTUM_ATR_SL_MULT=2.0
MOMENTUM_ATR_TP_MULT=3.0

# --- Strategy Parameters (Mean Reversion) ---
MEAN_REV_BB_PERIOD=20
MEAN_REV_BB_STD=2.0
MEAN_REV_ZSCORE_ENTRY=2.0
MEAN_REV_ZSCORE_EXIT=0.5
MEAN_REV_RSI_PERIOD=14

# --- ML Model ---
ML_MODEL_PATH=models/latest_model.joblib
ML_RETRAIN_INTERVAL_HOURS=24
ML_MIN_CONFIDENCE=0.65

# --- Notifications ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
NOTIFY_ON_TRADE=true
NOTIFY_ON_ERROR=true
NOTIFY_ON_SIGNAL=false

# --- Database ---
DATABASE_URL=sqlite:///data_cache/trading.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/trader.log

# --- Backtesting ---
BACKTEST_COMMISSION_PCT=0.001
BACKTEST_SLIPPAGE_PCT=0.0005
BACKTEST_INITIAL_CASH=10000.0
